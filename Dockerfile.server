# Runtime Stage
FROM eclipse-temurin:21-jre-jammy

RUN mkdir -p /app/uploads /app/data

# Copia tudo o que foi gerado pelo installDist
COPY deploy/server /app/

WORKDIR /app

EXPOSE 8080

ENV PUBLIC_HOST=localhost

# Executa o Java diretamente apontando para o classpath e a classe principal
# Isso evita problemas com scripts de inicialização de shell
CMD ["java", "-cp", "/app/lib/*", "com.itbenevides.genesys21.ApplicationKt"]
