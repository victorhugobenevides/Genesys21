# Runtime Stage (Nginx)
FROM nginx:stable-alpine

# Copiamos o nosso arquivo de configuração customizado
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Copiamos os arquivos da pasta developmentExecutable em vez de productionExecutable
COPY deploy/web /usr/share/nginx/html

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
